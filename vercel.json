{
  "buildCommand": "tsc -p tsconfig.app.json --noEmit && vite build",
  "outputDirectory": "dist/client",
  "installCommand": "pnpm install --frozen-lockfile",
  "rewrites": [
    { "source": "/analitico", "destination": "/index.html" },
    { "source": "/analitico/(.*)", "destination": "/index.html" }
  ]
}
